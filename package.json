{
	"name": "webpack-config",
	"packageManager": "yarn@4.5.2",
	"scripts": {
		"start": "webpack serve --env mode=development",
		"analyzer": "webpack --env mode=production",
		"build:dev": "webpack --env mode=development",
		"build:prod": "webpack --env mode=production --env analyzer=true",
		"build:ci": "webpack --env mode=production --env analyzer=false",
		"deploy": "gh-pages -d dist"
	},
	"devDependencies": {
		"@emailjs/browser": "^4.4.1",
		"@pmmmwh/react-refresh-webpack-plugin": "^0.5.17",
		"@svgr/webpack": "^8.1.0",
		"@swc/core": "^1.10.16",
		"@types/dotenv-webpack": "^7.0.8",
		"@types/gh-pages": "^6",
		"@types/node": "^25.9.1",
		"@types/react": "^19.0.8",
		"@types/react-dom": "^19.0.3",
		"@types/react-refresh": "^0",
		"@types/react-transition-group": "^4",
		"@types/webpack": "^5.28.5",
		"@types/webpack-bundle-analyzer": "^4",
		"copy-webpack-plugin": "^14.0.0",
		"css-loader": "^7.1.2",
		"cssnano": "^8.0.1",
		"dotenv-webpack": "^9.0.0",
		"fork-ts-checker-webpack-plugin": "^9.0.2",
		"gh-pages": "^6.3.0",
		"html-webpack-plugin": "^5.6.3",
		"mini-css-extract-plugin": "^2.9.2",
		"postcss": "^8.5.15",
		"postcss-loader": "^8.1.1",
		"postcss-merge-rules": "^8.0.0",
		"postcss-preset-env": "^11.3.0",
		"react-refresh": "^0.18.0",
		"sass": "^1.84.0",
		"sass-loader": "^17.0.0",
		"style-loader": "^4.0.0",
		"swc-loader": "^0.2.6",
		"ts-loader": "^9.5.2",
		"ts-node": "^10.9.2",
		"typescript": "^6.0.3",
		"webpack": "^5.107.2",
		"webpack-bundle-analyzer": "^5.3.0",
		"webpack-cli": "^6.0.1",
		"webpack-dev-server": "^5.2.4"
	},
	"dependencies": {
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"react-router": "^7.17.0",
		"react-transition-group": "^4.4.5"
	},
	"browserslist": {
		"production": [
			">0.2%",
			"not dead",
			"not op_mini all",
			"last 2 versions",
			"iOS >= 12",
			"Safari >= 12",
			"not ie <= 11"
		],
		"development": [
			"last 1 chrome version",
			"last 1 firefox version",
			"last 1 safari version"
		]
	}
}
